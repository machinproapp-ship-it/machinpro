# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA build artifacts (regenerated each build)
public/sw.js
public/workbox-*.js

.vercel

# AH-61 locale gap exports (regenerate with tsx scripts/ah61-export-gaps.ts)
scripts/.ah61-tmp/

# Run manually in Supabase SQL editor (do not commit)
src/lib/performance-indexes.sql
