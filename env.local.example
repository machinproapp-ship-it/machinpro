# Copy to .env.local and fill in. Do not commit secrets.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://machin.pro

# --- Google Tag Manager — injected only when NODE_ENV=production (see src/app/layout.tsx). ---
NEXT_PUBLIC_GTM_ID=GTM-WHR8FZMB

# --- Google Analytics 4 — Measurement ID for GTM / virtual pageviews (Ga4RouteAnalytics). ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Stripe (server: checkout, portal, webhook). LIVE keys only on Vercel Production. ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — override per environment (TEST vs LIVE). See src/lib/stripe-prices.ts.
STRIPE_PRICE_ESSENTIAL_MONTHLY=price_xxx
STRIPE_PRICE_ESSENTIAL_ANNUAL=price_xxx
STRIPE_PRICE_OPERATIONS_MONTHLY=price_xxx
STRIPE_PRICE_OPERATIONS_ANNUAL=price_xxx
STRIPE_PRICE_LOGISTICS_MONTHLY=price_xxx
STRIPE_PRICE_LOGISTICS_ANNUAL=price_xxx
STRIPE_PRICE_TODO_INCLUIDO_MONTHLY=price_xxx
STRIPE_PRICE_TODO_INCLUIDO_ANNUAL=price_xxx
STRIPE_PRICE_ADDITIONAL_USER=price_xxx

# Web Push (VAPID) — optional; push is skipped when keys are missing.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@machin.pro
