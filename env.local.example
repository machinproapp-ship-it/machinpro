# Copy to .env.local and fill in. Do not commit secrets.

# Google Tag Manager — public pages; only injected when NODE_ENV=production (see src/app/layout.tsx).
NEXT_PUBLIC_GTM_ID=GTM-WHR8FZMB

# Web Push (VAPID) — optional; push is skipped when keys are missing.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@machin.pro
